{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dewit playbook",
  "type": "object",
  "required": ["name", "tasks"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "hosts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "vars": { "type": "object" },
    "tasks": {
      "type": "array",
      "items": { "type": "object", "required": ["name"] }
    }
  }
}
